#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int main()
{
    int n = 3;

    int** arr = new int*[n];

    for(int i = 0; i < n; i++)
        arr[i] = new int[n];

    srand(time(0));

    int even = 0;
    int odd = 0;

    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < n; j++)
        {
            arr[i][j] = rand() % 100;
            cout << arr[i][j] << " ";

            if(arr[i][j] % 2 == 0)
                even++;
            else
                odd++;
        }
        cout << endl;
    }

    cout << "Main diagonal: ";

    for(int i = 0; i < n; i++)
        cout << arr[i][i] << " ";

    cout << endl;

    cout << "Secondary diagonal: ";

    for(int i = 0; i < n; i++)
        cout << arr[i][n - i - 1] << " ";

    cout << endl;

    cout << "Even: " << even << endl;
    cout << "Odd: " << odd << endl;

    for(int i = 0; i < n; i++)
        delete[] arr[i];

    delete[] arr;

    return 0;
}

