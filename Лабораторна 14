#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int main()
{
    int n = 10;

    float* arr = new float[n];

    srand(time(0));

    int positive = 0;
    int negative = 0;

    for(int i = 0; i < n; i++)
    {
        arr[i] = -2 + static_cast<float>(rand()) / RAND_MAX * 4;
        cout << arr[i] << " ";

        if(arr[i] > 0)
            positive++;
        else if(arr[i] < 0)
            negative++;
    }

    cout << endl;
    cout << "Positive: " << positive << endl;
    cout << "Negative: " << negative << endl;

    delete[] arr;

    return 0;
}
