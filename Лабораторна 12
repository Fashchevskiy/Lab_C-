#include <iostream>
using namespace std;

int main(void) {
    int vector[] = { 3, -5, 7, 10, -4, -14, 5, 2, -13 };
    int n = sizeof(vector) / sizeof(vector[0]);

    int* p = vector;          
    int minValue = *p;        

    p++; 

    for (int i = 1; i < n; i++) {
        if (*p < minValue) {
            minValue = *p;
        }
        p++;
    }

    cout << "Min element: " << minValue << endl;

    return 0;
}
