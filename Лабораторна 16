#include <iostream>
#include <ctime>
using namespace std;

struct Date {
    int year;
    int month;
    int day;
};


bool isLeap(int year) {
    return (year % 4 == 0 && year % 100 != 0) || (year % 400 == 0);
}


int monthLength(int year, int month) {
    int days[] = {31,28,31,30,31,30,31,31,30,31,30,31};
    if (month == 2 && isLeap(year)) return 29;
    return days[month - 1];
}


Date today(void) {
    time_t t = time(NULL); // 1c
    tm tl = *localtime(&t); //знач а не покажчик .розкл секунди на зручні календар дані

    Date current;
    current.year = tl.tm_year + 1900;
    current.month = tl.tm_mon + 1;
    current.day = tl.tm_mday;

    return current;
}


int daysBetween(Date d1, Date d2) {
    int days = 0;

    while (d1.year < d2.year || 
          (d1.year == d2.year && d1.month < d2.month) ||
          (d1.year == d2.year && d1.month == d2.month && d1.day < d2.day)) {
        
        d1.day++;
        days++;

        if (d1.day > monthLength(d1.year, d1.month)) { //переход на настп м
            d1.day = 1;
            d1.month++;
        }

        if (d1.month > 12) { // перех на наступ р
            d1.month = 1;
            d1.year++;
        }
    }

    return days;
}

int main() {
    Date birth;
    cout << "Enter your date of birth (year lunar day): ";
    cin >> birth.year >> birth.month >> birth.day;

    Date now = today(); // ПОТОЧ ДАТ

    int result = daysBetween(birth, now);

    cout << "Today:" << now.year << "-" << now.month << "-" << now.day << endl;
    cout << "Number of days since birth: " << result << endl;

    return 0;
}
